        end
        -- clear some local script caches to allow GC
        cachedSeedsInventory = nil
        RollSeedResponse = nil
        BuySeedResponses = {}
        -- run Lua garbage collector (call twice to be thorough)
        pcall(function() collectgarbage("collect") end)
        task.wait(0.05)
        pcall(function() collectgarbage("collect") end)
    end)
end

task.spawn(function()
    if not HiddenMemoryCleaner then return end
    while HiddenMemoryCleaner do
        pcall(runHiddenMemoryCleanupOnce)
