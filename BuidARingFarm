local cachedSeedsInventory = nil
local function matchesTargetSeed(seedName)
    local plantData = Registry.Plants[seedName]
    return Config.TargetSeeds[seedName] or (plantData and Config.TargetRanks[plantData.Rarity])
end
local function getSeedsInventory()
    if cachedSeedsInventory then return cachedSeedsInventory end
    for _, obj in pairs(getgc(true)) do
        if type(obj) == "table" and rawget(obj, "SeedsInventory") then
            cachedSeedsInventory = obj.SeedsInventory
            return cachedSeedsInventory
        end
    end
    return nil
end

local function findCashValue(root)
    for _, child in ipairs(root:GetChildren()) do
        if child:IsA("IntValue") or child:IsA("NumberValue") then
            local name = child.Name:lower()
            if name:match("cash") or name:match("money") or name:match("coin") or name:match("gold") or name:match("balance") or name:match("credit") then
                return child.Value
            end
        end
        if #child:GetChildren() > 0 then
            local val = findCashValue(child)
            if val then return val end
        end
    end
    return nil
end

local function getPlayerCash()
    local player = Players.LocalPlayer
    if not player then return nil end
    local leaderstats = player:FindFirstChild("leaderstats")
    if leaderstats then
        local cash = findCashValue(leaderstats)
        if cash then return cash end
    end
    local playerGui = player:FindFirstChild("PlayerGui")
    if playerGui then
        local cash = findCashValue(playerGui)
        if cash then return cash end
    end
    return nil
end

local function waitForCash(amount)
    local lastCash = getPlayerCash() or 0
    local noProgressCount = 0
    local maxNoProgress = 120
    while Config.AutoSeeds do
        local cash = getPlayerCash()
        if cash and cash >= amount then return true end
        if cash and cash > lastCash then lastCash = cash noProgressCount = 0 else noProgressCount = noProgressCount + 1 end
        if noProgressCount >= maxNoProgress then return false end
        task.wait(1)
    end
    return false
end

local function tryBuySeed(index)
    if BuySeedRemote:IsA("RemoteFunction") then
        local ok, result = pcall(function() return BuySeedRemote:InvokeServer(index) end)
        if not ok then return false, "error" end
        if result == true then return true, "ok" elseif result == false then return false, "cannot_afford" else return false, "unknown" end
    else
        local ok = pcall(function() BuySeedRemote:FireServer(index) end)
        if not ok then return false, "error" end
        local deadline = os.clock() + 3
        while os.clock() < deadline do
            if BuySeedResponses[index] ~= nil then
                local success = BuySeedResponses[index]
                BuySeedResponses[index] = nil
                if success then return true, "ok" else return false, "cannot_afford" end
            end
            task.wait(0.05)
        end
        return false, "unknown"
    end
end

