local function isShooterTool(tool, pConfig)
    if not tool or not tool:IsA("Tool") then return false end
    return tool:GetAttribute(pConfig.Shooter.Attribute) == true or tool.Name == pConfig.Shooter.ToolName
end

local function getPlantTargets(origin, pConfig)
    local runtime = workspace:FindFirstChild("InteractiveEvents") and workspace.InteractiveEvents:FindFirstChild("PlantRush")
    if not runtime then return {} end

    local targets = {}
    for _, model in ipairs(runtime:GetDescendants()) do
        if model:IsA("Model") and model:GetAttribute("PlantRushId") then
            local part = model.PrimaryPart or model:FindFirstChild("HumanoidRootPart", true) or model:FindFirstChildWhichIsA("BasePart", true)
            if part then
                local dist = (part.Position - origin).Magnitude
                if dist > 0 and dist <= (pConfig.Shooter.Range or 100) then
                    table.insert(targets, {part = part, dist = dist})
                end
            end
        end
    end
    table.sort(targets, function(a, b) return a.dist < b.dist end)
    return targets
end

