local realName = LocalPlayer.Name
local realDisplayName = LocalPlayer.DisplayName

local function censorName(name)
    if #name <= 3 then return name .. "..." end
    return string.sub(name, 1, 3) .. "........"
end

local maskedName = censorName(realName)
local maskedDisplayName = censorName(realDisplayName)
local prefixName = string.sub(realName, 1, 6)
local prefixDisplay = string.sub(realDisplayName, 1, 6)

local function isTextObject(obj)
    return obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")
end

local function censorGuiText(element)
    if not isTextObject(element) then return end
    local success, txt = pcall(function() return element.Text end)
    if not success or not txt or txt == "" then return end

    if txt:find(prefixDisplay, 1, true) and not txt:find(maskedDisplayName, 1, true) and txt ~= "Bustupid Hub" then
        element.Text = maskedDisplayName
    elseif txt:find(prefixName, 1, true) and not txt:find(maskedName, 1, true) then
        element.Text = "@" .. maskedName
    end
end

local function scanGui(gui)
    if not gui or not gui:IsA("ScreenGui") then return end
    if gui.Name:find("Roblox") or gui.Name:find("Core") then return end
    for _, element in ipairs(gui:GetDescendants()) do censorGuiText(element) end
end

local function watchGui(gui)
    if not gui or not gui:IsA("ScreenGui") then return end
    if gui.Name:find("Roblox") or gui.Name:find("Core") then return end
    gui.DescendantAdded:Connect(function(descendant) censorGuiText(descendant) end)
    scanGui(gui)
end

local function scanAllGui()
    pcall(function() for _, gui in ipairs(game:GetService("CoreGui"):GetChildren()) do scanGui(gui) end end)
    pcall(function() for _, gui in ipairs(LocalPlayer:WaitForChild("PlayerGui"):GetChildren()) do scanGui(gui) end end)
end

local function watchGuiContainer(container)
    if not container then return end
    container.ChildAdded:Connect(function(child) if child:IsA("ScreenGui") then watchGui(child) end end)
    for _, child in ipairs(container:GetChildren()) do if child:IsA("ScreenGui") then watchGui(child) end end
end

