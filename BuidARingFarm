local function getMyPlot()
    local plotRemote = findGetPlotRemote()
    if not plotRemote then
        return nil
    end

    local ok, myPlot = pcall(function() return plotRemote:InvokeServer() end)
    if not ok or not myPlot then
        return nil
    end

    local plotModel = resolvePlotInstance(myPlot)
    if not plotModel then
        return nil
    end

    if plotModel:GetAttribute("DataLoaded") ~= true then
        local attrSuccess, _ = pcall(function()
            plotModel:GetAttributeChangedSignal("DataLoaded")
        end)
        if attrSuccess then
            local deadline = tick() + 3
            while tick() < deadline and plotModel:GetAttribute("DataLoaded") ~= true do
                task.wait(0.1)
            end
        end
    end

    return plotModel
end

TeleportToMyFarm = function()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local rootPart = character and character:WaitForChild("HumanoidRootPart", 3)
    if not rootPart then return end

    local myPlot = getMyPlot()
    if not myPlot then
        Fluent:Notify({Title="Teleport Failed", Content="Không tìm thấy plot của bạn", Duration=4})
        return
    end

    local plotModel = resolvePlotInstance(myPlot)
    if not plotModel then
        Fluent:Notify({Title="Teleport Failed", Content="Plot không hợp lệ", Duration=4})
        return
    end

    local targetCFrame
    local sign = plotModel:FindFirstChild("OwnerSign", true)
    if sign then
        local attach = sign:FindFirstChildWhichIsA("Attachment", true)
        if attach then
            targetCFrame = attach.WorldCFrame
        elseif sign:IsA("BasePart") then
            targetCFrame = sign.CFrame
        elseif sign.PrimaryPart then
            targetCFrame = sign.PrimaryPart.CFrame
        else
            local basePart = sign:FindFirstChildWhichIsA("BasePart", true)
            if basePart then
                targetCFrame = basePart.CFrame
            end
        end
    end

    if not targetCFrame then
        local success, pivot = pcall(function() return plotModel:GetPivot() end)
        if success and pivot then
            targetCFrame = pivot
        end
    end

    if not targetCFrame then
        local basePart = plotModel.PrimaryPart or plotModel:FindFirstChildWhichIsA("BasePart", true)
        if basePart then
            targetCFrame = basePart.CFrame
        end
    end

    if targetCFrame then
        rootPart.CFrame = targetCFrame * CFrame.new(0, 5, 0)
        return
    end

    Fluent:Notify({Title="Teleport Failed", Content="Không thể xác định vị trí farm", Duration=4})
end

