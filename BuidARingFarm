local lastCollectTime = 0
local collectDelay = 0.75  -- delay giữa các lần collect (giây) - đồng bộ với Queen Bee

-- Lắng nghe event DropSpawned: khi drop mới xuất hiện
if DropSpawnedRemote and DropClaimRemote then
    DropSpawnedRemote.OnClientEvent:Connect(function(dropData)
        if Config.AutoPlantRushCollect and dropData and dropData.DropId then
            local dropId = dropData.DropId
            
            -- Tránh collect lại drop cũ
            if collectedDropIds[dropId] then return end
            collectedDropIds[dropId] = true
            
            task.spawn(function()
                -- Đợi cooldown giữa các lần collect
                local now = os.clock()
                if now - lastCollectTime < collectDelay then
                    task.wait(collectDelay - (now - lastCollectTime))
                end
                
                if not Config.AutoPlantRushCollect then return end
                
                -- Lấy vị trí từ dropData
                local position = dropData.Position
                if typeof(position) == "Vector3" then
                    local char = LocalPlayer.Character
                    local hrp = char and char:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        -- Teleport đến drop
                        hrp.CFrame = CFrame.new(position + Vector3.new(0, 5, 0))
                        task.wait(0.2)
                        
                        -- Fire claim
                        pcall(function()
                            DropClaimRemote:FireServer(dropId)
                        end)
                        
                        lastCollectTime = os.clock()
                        task.wait(0.15)
                    end
                end
            end)
        end
    end)
end

-- Scan loop: tìm drop trong workspace và collect nếu chưa collect
task.spawn(function()
    while task.wait(0.5) do
        if Config.AutoPlantRushCollect and DropClaimRemote then
            pcall(function()
                for _, obj in ipairs(workspace:GetChildren()) do
                    if obj:IsA("BasePart") and obj.Name:match("^PlantRushLocalDrop_") then
                        -- Extract drop ID từ object name
                        local dropId = obj.Name:gsub("PlantRushLocalDrop_", "")
                        
                        -- Nếu chưa collect drop này
                        if not collectedDropIds[dropId] then
                            collectedDropIds[dropId] = true
                            
                            task.spawn(function()
                                -- Đợi cooldown
                                local now = os.clock()
                                if now - lastCollectTime < collectDelay then
                                    task.wait(collectDelay - (now - lastCollectTime))
                                end
                                
                                if not Config.AutoPlantRushCollect then return end
                                
                                local char = LocalPlayer.Character
                                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                                if hrp then
                                    -- Teleport đến drop
                                    hrp.CFrame = CFrame.new(obj.Position + Vector3.new(0, 5, 0))
                                    task.wait(0.2)
                                    
                                    -- Fire claim
                                    pcall(function()
                                        DropClaimRemote:FireServer(dropId)
                                    end)
                                    
                                    lastCollectTime = os.clock()
                                    task.wait(0.2)
                                end
                            end)
                        end
                        
                        -- Ẩn drop để không lag
                        obj.Transparency = 1
                        local prompt = obj:FindFirstChildOfClass("ProximityPrompt")
                        if prompt then prompt:Destroy() end
                    end
                end
            end)
        end
    end
end)

-- Cleanup: clear collected drops mỗi 30 giây để tránh memory leak
task.spawn(function()
    while task.wait(30) do
        collectedDropIds = {}
    end
end)
