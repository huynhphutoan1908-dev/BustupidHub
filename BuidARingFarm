local function findGetPlotRemote()
    if PlotRemoteFolder then
        local candidate = PlotRemoteFolder:FindFirstChild("GetPlot")
        if candidate and candidate:IsA("RemoteFunction") then
            return candidate
        end
    end

    local direct = Remotes:FindFirstChild("GetPlot")
    if direct and direct:IsA("RemoteFunction") then
        return direct
    end

    for _, child in pairs(Remotes:GetChildren()) do
        if child:IsA("RemoteFunction") and child.Name:lower():match("getplot") then
            return child
        end
        if child:IsA("Folder") then
            local nested = child:FindFirstChild("GetPlot")
            if nested and nested:IsA("RemoteFunction") then
                return nested
            end
        end
    end

    return nil
end

local function resolvePlotInstance(plotResponse)
    if typeof(plotResponse) == "Instance" then
        return plotResponse
    end

    if type(plotResponse) == "table" then
        if typeof(plotResponse.Plot) == "Instance" then
            return plotResponse.Plot
        end
        if typeof(plotResponse.PlotModel) == "Instance" then
            return plotResponse.PlotModel
        end
        if typeof(plotResponse.Model) == "Instance" then
            return plotResponse.Model
        end

        for _, value in pairs(plotResponse) do
            if typeof(value) == "Instance" then
                return value
            end
        end
    end

    return nil
end

