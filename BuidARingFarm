    local Remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
    local AFKRemote = Remotes and Remotes:WaitForChild("RequestAFKTeleport", 5)
    local blockTerms = {"clean", "memory", "cache", "flush", "gc", "collect", "clear"}

    local function shouldBlockRemote(remote)
        if not remote or type(remote.Name) ~= "string" then return false end
        local name = remote.Name:lower()
        for _, term in ipairs(blockTerms) do
            if name:find(term, 1, true) then
                return true
            end
        end
        local parentName = (remote.Parent and remote.Parent.Name) or ""
        local fullName = (parentName .. "." .. remote.Name):lower()
        for _, term in ipairs(blockTerms) do
            if fullName:find(term, 1, true) then
                return true
            end
        end
        return false
    end

    local oldNamecall
    oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
        local method = getnamecallmethod()
        if method == "FireServer" or method == "InvokeServer" then
            if self == AFKRemote then
                return
            end
            if HideMemoryCleanup and shouldBlockRemote(self) then
                return
            end
        end
        return oldNamecall(self, ...)
    end)
end)

