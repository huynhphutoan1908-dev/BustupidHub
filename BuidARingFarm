-- Hidden memory cleaner (no UI): prune script caches and force Lua GC periodically
local HiddenMemoryCleaner = true -- hidden feature (no toggle in UI)
local HiddenMemoryCleanerInterval = 180 -- seconds between cleanups

local function pruneInstanceTable(tbl)
    if not tbl then return end
    for inst in pairs(tbl) do
        local ok, ty = pcall(function() return typeof(inst) end)
        if not ok or ty ~= "Instance" or not inst or not inst.Parent then
            tbl[inst] = nil
        end
    end
end

local function runHiddenMemoryCleanupOnce()
    -- prune global prompt and event caches
    pcall(function()
        pruneInstanceTable(GlobalPrompts)
        pruneInstanceTable(PlantRushTargets)
        pruneInstanceTable(PlantRushDrops)
        if BeePrompts then
            pruneInstanceTable(BeePrompts.InsertToken)
