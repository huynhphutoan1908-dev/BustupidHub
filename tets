local function getToolScore(tool)
    if not tool or type(tool.IsA) ~= "function" or not tool:IsA("Tool") then return -math.huge end
    local score = 0
    if type(tool.GetAttribute) == "function" then
        score = tool:GetAttribute("Score") or tool:GetAttribute("PlantScore") or tool:GetAttribute("Quality") or tool:GetAttribute("Power") or tool:GetAttribute("Value") or 0
    end
    local name = tool.Name and tool.Name:lower() or ""
    if name:find("mythic") then score = score + 1000
    elseif name:find("legendary") then score = score + 500
    elseif name:find("epic") then score = score + 250
    elseif name:find("rare") then score = score + 100
    elseif name:find("uncommon") then score = score + 50
    end
    return score
end

local function getBestSeed()
    local bestTool, bestScore = nil, -math.huge
    local function scanContainer(container)
        if not container then return end
        for _, item in ipairs(container:GetChildren()) do
            if item:IsA("Tool") then
                local score = getToolScore(item)
                if score > bestScore then
                    bestScore = score
                    bestTool = item
                end
            end
        end
    end

    scanContainer(LocalPlayer:FindFirstChild("Backpack"))
    scanContainer(LocalPlayer.Character)
    return bestTool, bestScore
end

