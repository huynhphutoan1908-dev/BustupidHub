                                SprayRemote:FireServer(dirty[1])
                                task.wait(0.4)
                                equipTool(targetSpray)
                                SprayRemote:FireServer(dirty[1])
                                task.wait(0.3)
                            end
                        end
                    end
                end)
                task.wait(1.5)
            end
