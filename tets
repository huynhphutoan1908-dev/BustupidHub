    workspace.DescendantAdded:Connect(trackPlantRushDescendant)
    workspace.DescendantRemoving:Connect(function(obj)
        if obj:IsA("BasePart") then untrackPlantRushDrop(obj)
        elseif obj:IsA("ProximityPrompt") then untrackPlantRushPrompt(obj) end
    end)
end)

local function getNearestPlantRushDrop(origin)
    local closestPart, closestId, bestDist = nil, nil, math.huge
    for part, id in pairs(trackedPlantRushDrops) do
        if part and part.Parent and part:IsA("BasePart") then
            local dist = (part.Position - origin).Magnitude
            if dist < bestDist and dist <= plantRushCollectMaxDistance then
                bestDist = dist
                closestPart = part
                closestId = id
            end
        end
    end
    return closestPart, closestId
end

local function findPlantRushPrompt(part)
    local current = part
    while current do
        if current:IsA("ProximityPrompt") then return current end
        for _, descendant in ipairs(current:GetDescendants()) do
            if descendant:IsA("ProximityPrompt") then return descendant end
        end
        current = current.Parent
    end
    return nil
end

local function collectPlantRushDrops()
    if not DropClaimRemote then return end
    local char = LocalPlayer.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    if os.clock() - lastPlantRushCollectTime < plantRushCollectDelay then return end

    cleanupPlantRushDrops()
    cleanupPlantRushPrompts()

    local prompt, promptDropPart = getNearestTrackedPlantRushPrompt(hrp.Position)
    if prompt and promptDropPart then
        local dist = (promptDropPart.Position - hrp.Position).Magnitude
        lastPlantRushCollectTime = os.clock()
        if dist > plantRushTeleportThreshold then
            pcall(function() hrp.CFrame = CFrame.new(promptDropPart.Position + Vector3.new(0, 4, 0)) end)
            task.wait(0.22)
        end
        pcall(function() fireproximityprompt(prompt) end)
        trackedPlantRushPrompts[prompt] = nil
        trackedPlantRushDrops[promptDropPart] = nil
        return
    end

    local part, dropId = getNearestPlantRushDrop(hrp.Position)
    if not part or not dropId then return end

    local dist = (part.Position - hrp.Position).Magnitude
    lastPlantRushCollectTime = os.clock()
    if dist > plantRushTeleportThreshold then
        pcall(function() hrp.CFrame = CFrame.new(part.Position + Vector3.new(0, 4, 0)) end)
        task.wait(0.22)
    end

    pcall(function()
        local prompt = findPlantRushPrompt(part)
        if prompt then fireproximityprompt(prompt)
        elseif DropClaimRemote:IsA("RemoteFunction") then DropClaimRemote:InvokeServer(dropId)
        else DropClaimRemote:FireServer(dropId) end
    end)
    trackedPlantRushDrops[part] = nil
end

task.spawn(function()
    while task.wait(0.18) do
        if Config.AutoPlantRushCollect then pcall(collectPlantRushDrops) end
    end
end)

local function getClosestBeePrompt(list, origin)
    local closest, bestDist = nil, math.huge
    for _, prompt in ipairs(list) do
        if prompt and prompt.Parent and prompt.Parent:IsA("BasePart") then
            local dist = (prompt.Parent.Position - origin).Magnitude
            if dist < bestDist then
                bestDist = dist
                closest = prompt
            end
        end
    end
    return closest
end

