local function LoadAutoSellFeature(Tab)
    local petList, rankList, PetDataCache = {}, {}, {}

    local rankOrder = {
        ["Common"] = 1, ["Uncommon"] = 2, ["Rare"] = 3, ["Epic"] = 4, 
        ["Legendary"] = 5, ["Mythic"] = 6, ["Secret"] = 7, ["Divine"] = 8, ["Exclusive"] = 9
    }

    pcall(function()
        local PetsModule = require(game:GetService("ReplicatedStorage").Shared.Registry.Pets)
        for _, pet in ipairs(PetsModule.GetPetsForIndex()) do
            if pet.Name then
                if not table.find(petList, pet.Name) then table.insert(petList, pet.Name) end
                if pet.Rarity then
                    PetDataCache[pet.Name] = pet.Rarity 
                    if not table.find(rankList, pet.Rarity) then table.insert(rankList, pet.Rarity) end
                end
            end
        end
    end)

    table.sort(petList)
    table.sort(rankList, function(a, b)
        return (rankOrder[a] or 99) < (rankOrder[b] or 99)
    end)

    local RankDropdown = Tab:AddDropdown("KeepRanks", {
        Title = "Keep by Rarity",
        Values = rankList,
        Multi = true,
        Default = {}
    })

    local NameDropdown = Tab:AddDropdown("KeepNames", {
        Title = "Keep by Name",
        Values = petList,
        Multi = true,
        Default = {}
    })

    local autoSell = false
    local sellRemote = game:GetService("ReplicatedStorage"):WaitForChild("Remotes"):WaitForChild("SellPet")

    local playerDataCache = nil
    local playerDataLastRefresh = 0
    local playerDataRefreshInterval = 10.0
    local sellQueue = {}
    local sellIndex = 1
    local sellDelay = 2.0

    local virtualRam = {
        Cache = nil,
        LastUpdate = 0,
        Expiry = 60.0,
    }

    local gcPetData = nil
    local function isValidPetData(data)
        return type(data) == "table" and rawget(data, "PetInventory") and rawget(data, "EquippedPets")
    end

    local function getPlayerDataFromGC()
        if isValidPetData(gcPetData) then
            return gcPetData
        end

        for _, v in pairs(getgc(true)) do
            if isValidPetData(v) then
                gcPetData = v
                return v
            end
        end
        return nil
    end

    local function cacheVirtualRam(data, now)
        virtualRam.Cache = data
        virtualRam.LastUpdate = now
    end

    local function getPlayerData()
        local now = os.clock()
        if playerDataCache and now - playerDataLastRefresh < playerDataRefreshInterval then
            return playerDataCache
        end

        local data = getPlayerDataFromGC()
        if data then
            playerDataCache = data
            playerDataLastRefresh = now
            cacheVirtualRam(data, now)
            return data
        end

        if virtualRam.Cache and now - virtualRam.LastUpdate < virtualRam.Expiry then
            return virtualRam.Cache
        end

        return nil
    end

    local function trySellPet(id)
        if sellRemote:IsA("RemoteFunction") then
            pcall(function() sellRemote:InvokeServer(id) end)
        else
            pcall(function() sellRemote:FireServer(id) end)
        end
    end

    local function buildSellQueue()
        local data = getPlayerData()
        if not data or not data.PetInventory then
            return {}
        end

        local equipped = {}
        for _, id in pairs(data.EquippedPets or {}) do
            equipped[id] = true
        end

        local selRanks = RankDropdown.Value or {}
        local selNames = NameDropdown.Value or {}
        local queue = {}

        for id, info in pairs(data.PetInventory) do
            local name = info.Name or ""
            if not equipped[id] then
                local rank = PetDataCache[name] or "Unknown"
                if not (selRanks[rank] or selNames[name] or name == "Kitsune") then
                    queue[#queue + 1] = id
                end
            end
        end

        return queue
    end

    Tab:AddToggle("AutoSellPets", {
        Title = "Enable Auto Sell Pets",
        Default = false,
        Callback = function(state)
            autoSell = state
            if not autoSell then
                sellQueue = {}
                sellIndex = 1
                playerDataCache = nil
                return
            end

            sellQueue = {}
            sellIndex = 1
            playerDataCache = nil

            task.spawn(function()
                while autoSell do
                    if sellIndex > #sellQueue then
                        sellQueue = buildSellQueue()
                        sellIndex = 1
                        if #sellQueue == 0 then
                            task.wait(3.0)
                            continue
                        end
                    end

                    local id = sellQueue[sellIndex]
                    sellIndex = sellIndex + 1
                    if id then
                        trySellPet(id)
                        task.wait(sellDelay)
                    end
                end
            end)
        end
    })
end

