local function findNamedRemote(namePatterns)
    for _, child in ipairs(Remotes:GetDescendants()) do
        if child:IsA("RemoteFunction") or child:IsA("RemoteEvent") then
            local lowerName = child.Name:lower()
            for _, pattern in ipairs(namePatterns) do
                if lowerName:find(pattern:lower()) then
                    return child
                end
            end
        end
    end
    return nil
end

local function findGearTool(tag, mutOrName)
    local function search(folder)
        if not folder then return nil end
        for _, tool in ipairs(folder:GetChildren()) do
            if tool:IsA("Tool") and CollectionService:HasTag(tool, tag) then
                local m = tool:GetAttribute("Mutation")
                if m == mutOrName or (mutOrName == "None" and tool.Name:match("Acid")) then return tool end
            end
        end
    end
    return search(LocalPlayer.Character) or search(LocalPlayer:FindFirstChild("Backpack"))
end

local function scanPlantPlots()
    local emptyPlots, plantedPlots = {}, {}
    local myPlot = getMyPlot()
    if not myPlot then return emptyPlots, plantedPlots end

    local function addPlot(plot)
        if not plot or type(plot.IsA) ~= "function" then return end
        local dirt = plot:FindFirstChild("Dirt")
        if dirt then
            local planted = plot:FindFirstChild("Plant") or plot:FindFirstChild("Crop") or plot:FindFirstChild("Seed")
            if planted then
                local score = 0
                if type(planted.GetAttribute) == "function" then
                    score = planted:GetAttribute("Score") or planted:GetAttribute("Quality") or planted:GetAttribute("Power") or 0
                end
                table.insert(plantedPlots, {Dirt = dirt, Score = score})
            else
                table.insert(emptyPlots, dirt)
            end
        end
    end

    for _, desc in ipairs(myPlot:GetDescendants()) do
        if desc:IsA("Model") then
            addPlot(desc)
        end
    end
    return emptyPlots, plantedPlots
end

local function plantBestSeedTick()
    if not Config.AutoPlantBest then return end
    local plantRemote = findNamedRemote({"plant", "plantseed"})
    local removeRemote = findNamedRemote({"remove", "removeseed", "removetree", "removesapling"})
    if not plantRemote then return end

    local bestTool, bestScore = getBestSeed()
    if not bestTool then return end

    local emptyPlots, plantedPlots = scanPlantPlots()
    if #emptyPlots > 0 then
        equipTool(bestTool)
        pcall(function()
            if plantRemote:IsA("RemoteFunction") then plantRemote:InvokeServer(emptyPlots[1])
            else plantRemote:FireServer(emptyPlots[1]) end
        end)
        task.wait(0.2)
    elseif #plantedPlots > 0 and removeRemote then
        table.sort(plantedPlots, function(a, b) return a.Score < b.Score end)
        if bestScore > plantedPlots[1].Score then
            pcall(function()
                if removeRemote:IsA("RemoteFunction") then removeRemote:InvokeServer(plantedPlots[1].Dirt)
                else removeRemote:FireServer(plantedPlots[1].Dirt) end
            end)
            task.wait(0.3)
            equipTool(bestTool)
            pcall(function()
                if plantRemote:IsA("RemoteFunction") then plantRemote:InvokeServer(plantedPlots[1].Dirt)
                else plantRemote:FireServer(plantedPlots[1].Dirt) end
            end)
            task.wait(0.2)
        end
    end
end

