-- 3. AUTO PET SCAN SYSTEM
local DynamicPetList = {"All"}
for petName, _ in pairs(PetModules) do
    if type(petName) == "string" then
        table.insert(DynamicPetList, petName)
    end
end
table.sort(DynamicPetList, function(a, b)
    if a == "All" then return true end
    if b == "All" then return false end
    return a < b
end)

-- Rank list
local RankList = {
    "All",
    "Common",
    "Uncommon",
    "Rare",
    "Super",
    "Epic",
    "Legendary",
    "Mythic"
}

local ConfigFileName = "DanielRobloxStoreConfig.json"
local Config = {
    AutoTameTeleport = false,
    AutoServerHop = false,
    AutoExecute = false,
    TargetPet = "All",
    TargetRank = "All"
}

local function canSaveConfig()
    return type(writefile) == "function" and type(readfile) == "function" and type(isfile) == "function"
end

local function saveConfig()
    if not canSaveConfig() then return end
    local success, encoded = pcall(function() return HttpService:JSONEncode(Config) end)
    if success then pcall(writefile, ConfigFileName, encoded) end
end

local function loadConfig()
    if not canSaveConfig() or not isfile(ConfigFileName) then return end
    local contents = nil
    pcall(function() contents = readfile(ConfigFileName) end)
    if not contents then return end
    local ok, decoded = pcall(function() return HttpService:JSONDecode(contents) end)
    if ok and type(decoded) == "table" then
        for key, value in pairs(decoded) do
            if Config[key] ~= nil then Config[key] = value end
        end
    end
end

loadConfig()

local function enableAutoExecuteAfterDelay()
    task.spawn(function()
        task.wait(3)
        if Config.AutoExecute then
            Config.AutoTameTeleport = true
            saveConfig()
        end
    end)
end

if Config.AutoExecute then enableAutoExecuteAfterDelay() end

-- ===================================================
-- HỆ THỐNG CUSTOM SERVER HOP (NÉ BẠN BÈ / SERVER CŨ)
-- ===================================================
local function CustomServerHop()
    local PlaceId = game.PlaceId
    local ApiUrl = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"
    
    pcall(function()
        local response = game:HttpGet(ApiUrl)
        local data = HttpService:JSONDecode(response)
        
        if data and data.data then
            local availableServers = {}
            for _, server in ipairs(data.data) do
                -- Lọc: Server không đầy & Khác với server hiện tại
                if type(server) == "table" and server.playing < server.maxPlayers - 1 and server.id ~= game.JobId then
                    table.insert(availableServers, server.id)
                end
            end
            
            if #availableServers > 0 then
                -- Chọn random 1 server trong danh sách để tránh bị dồn chung với các bot khác
                local randomServerId = availableServers[math.random(1, #availableServers)]
                TeleportService:TeleportToPlaceInstance(PlaceId, randomServerId, LocalPlayer)
            end
        end
    end)
end

local function findIndex(list, value)
    for index, item in ipairs(list) do
        if item == value then return index end
    end
    return 1
end

