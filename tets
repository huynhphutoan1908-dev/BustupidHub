-- HỆ THỐNG GỬI DISCORD WEBHOOK
-- ===================================================
local request_func = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
local function SendWebhook(petName, petRank)
    if not Config.UseWebhook or Config.WebhookURL == "" or not request_func then return end
    
    local embedData = {
        ["title"] = "🎉 BẮT THÀNH CÔNG THÚ CƯNG!",
        ["color"] = 65280, -- Màu xanh lá
        ["fields"] = {
            {["name"] = "🐾 Tên Pet:", ["value"] = tostring(petName), ["inline"] = true},
            {["name"] = "⭐ Độ Hiếm (Rank):", ["value"] = tostring(petRank), ["inline"] = true},
            {["name"] = "👤 Tài Khoản:", ["value"] = "||" .. LocalPlayer.Name .. "||", ["inline"] = false}
        },
        ["footer"] = {["text"] = "DanielRoblox.Store | Auto Logger"}
    }
    
    local payload = HttpService:JSONEncode({
        ["username"] = "Daniel Store",
        ["avatar_url"] = "https://i.imgur.com/8QG4sS4.png", -- Bạn có thể thay link logo của store vào đây
        ["embeds"] = {embedData}
    })
    
    task.spawn(function()
        pcall(function()
            request_func({
                Url = Config.WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = payload
            })
        end)
    end)
end

-- ===================================================
-- CUSTOM HOP FIX LỖI 773
-- ===================================================
local recentServerIds = {}

local function FetchServerPages(placeId, maxPages)
    local servers = {}
    local cursor = nil
    for page = 1, maxPages or 5 do
        local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Asc&limit=100"
        if cursor then
            url = url .. "&cursor=" .. HttpService:UrlEncode(cursor)
        end

        local success, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        if not success or not result or not result.data then
            break
        end

        for _, server in ipairs(result.data) do
            if type(server) == "table" then
                table.insert(servers, server)
            end
        end

        if not result.nextPageCursor then
            break
        end
        cursor = result.nextPageCursor
    end
    return servers
end

local function CustomServerHop()
    Fluent:Notify({Title = "Hopping...", Content = "Finding a different server", Duration = 3})
    local success, result = pcall(function()
        return HttpService:JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
    end)
    if success and result and result.data then
        local validServers = {}
        for _, server in ipairs(result.data) do
            if server.id ~= game.JobId and not recentServerIds[server.id] then
                table.insert(validServers, server.id)
            end
        end
        if #validServers > 0 then
            local randomServer = validServers[math.random(1, #validServers)]
            recentServerIds[randomServer] = true
            local count = 0
            for _ in pairs(recentServerIds) do count = count + 1 end
            if count > 5 then recentServerIds = {} end
            TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServer, LocalPlayer)
        else
            Fluent:Notify({Title = "Error", Content = "No available servers found", Duration = 3})
        end
    end
end

local function findIndex(list, value)
    for index, item in ipairs(list) do if item == value then return index end end
    return 1
end

