local function setToggleState(toggle, value)
    if not toggle then return end
    if type(toggle.Set) == "function" then
        pcall(toggle.Set, toggle, value)
    elseif type(toggle.SetValue) == "function" then
        pcall(toggle.SetValue, toggle, value)
    elseif type(toggle.SetState) == "function" then
        pcall(toggle.SetState, toggle, value)
    end
end

