local function unlockPlotScan()
    if not Config.AutoUnlockPlot then return end
    local unlockRemote = findUnlockRemote()
    if not unlockRemote then return end

    local myPlot = getMyPlot()
    if not myPlot then return end

    local unlockedTick = false
    for _, plot in ipairs(myPlot:GetDescendants()) do
        if unlockedTick then break end
        local u = nil
        if type(plot.GetAttribute) == "function" then u = plot:GetAttribute("Unlocked") end
        local grass = nil
        local dirt = nil
        if type(plot.FindFirstChild) == "function" then
            grass = plot:FindFirstChild("Grass")
            dirt = plot:FindFirstChild("Dirt")
        end
        local isLocked = (u == false) or (u == nil and grass and grass.Transparency == 0)

        if isLocked and (grass or dirt) then
            local target = grass or dirt
            if target then
                pcall(function()
                    if unlockRemote:IsA("RemoteFunction") then unlockRemote:InvokeServer(target)
                    else unlockRemote:FireServer(target) end
                end)
                unlockedTick = true
            end
        end
    end
end

