-- VÒNG LẶP SĂN PET
-- ===================================================
task.spawn(function()
    while task.wait(1) do 
        if Config.AutoTameTeleport then
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local wildPetRef = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WildPetRef")
                if not hrp or not wildPetRef then return end
                
                local hasMatchingPet = false 
                
                for _, petPart in pairs(wildPetRef:GetChildren()) do
                    if petPart:IsA("BasePart") then
                        local owner = petPart:GetAttribute("OwnerUserId")
                        local petName = petPart:GetAttribute("PetName") or ""
                        local petRarity = petPart:GetAttribute("Rarity") or "Common"
                        if petRarity == "" then petRarity = "Common" end
                        
                        if not owner or owner == 0 then
                            local matchPet = (Config.TargetPet == "All" or petName == Config.TargetPet)
                            local matchRank = (Config.TargetRank == "All" or petRarity == Config.TargetRank)
                            
                            if matchPet and matchRank then
                                hasMatchingPet = true 
                                hrp.CFrame = petPart.CFrame * CFrame.new(0, 3, 0)
                                task.wait(0.4) 
                                Networking.Pets.WildPetTame:Fire(petPart)

                                -- GỌI WEBHOOK BÁO KẾT QUẢ VỀ DISCORD!
                                SendWebhook(petName, petRarity)
                                
                                Config.AutoServerHop = false
                                saveConfig()
                                setToggleState(HopToggle, false)
                                
                                task.wait(0.6)
                            end
                        end
                    end
                end
                
                if not hasMatchingPet and Config.AutoServerHop then
                    Fluent:Notify({ Title = "Server Hop", Content = "No matching pet. Bypassing Error 773 & Hopping...", Duration = 4 })
                    CustomServerHop()
                    task.wait(12) 
                end
            end)
        end
    end
end)

