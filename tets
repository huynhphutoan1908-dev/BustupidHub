local Players = game:GetService("Players")
local RS = game:GetService("ReplicatedStorage")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local LocalPlayer = Players.LocalPlayer

local Networking = require(RS:WaitForChild("SharedModules"):WaitForChild("Networking"))
local PetModules = require(RS:WaitForChild("SharedModules"):WaitForChild("PetModules"))

local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "DanielRoblox.Store",
    SubTitle = "Auto Pet",
    TabWidth = 160,
    Size = UDim2.fromOffset(500, 420),
    Theme = "Darker"
})

local Tabs = { Pets = Window:AddTab({ Title = "Catch Pets", Icon = "paw" }) }

-- Quét Pet
local DynamicPetList = {"All"}
for petName, _ in pairs(PetModules) do
    if type(petName) == "string" then table.insert(DynamicPetList, petName) end
end
table.sort(DynamicPetList, function(a, b) return a == "All" or (b ~= "All" and a < b) end)

local RankList = {"All", "Common", "Uncommon", "Rare", "Super", "Epic", "Legendary", "Mythic"}

local ConfigFileName = "DanielRobloxStoreConfig.json"
local Config = {
    AutoTameTeleport = false,
    AutoServerHop = false,
    AutoExecute = false,
    TargetPet = "All",
    TargetRank = "All"
}

-- Hệ thống lưu cấu hình
local function canSaveConfig() return type(writefile) == "function" end
local function saveConfig()
    if canSaveConfig() then pcall(writefile, ConfigFileName, HttpService:JSONEncode(Config)) end
end
if canSaveConfig() and isfile(ConfigFileName) then
    pcall(function()
        local decoded = HttpService:JSONDecode(readfile(ConfigFileName))
        for k, v in pairs(decoded) do if Config[k] ~= nil then Config[k] = v end end
    end)
end

local function enableAutoExecuteAfterDelay()
    task.spawn(function()
        task.wait(3)
        if Config.AutoExecute then
            Config.AutoTameTeleport = true
            saveConfig()
        end
    end)
end
if Config.AutoExecute then enableAutoExecuteAfterDelay() end

-- ===================================================
-- CUSTOM HOP FIX LỖI 773 CỰC MẠNH
-- ===================================================
local function CustomServerHop()
    local PlaceId = game.PlaceId
    -- Đổi sang Desc để lấy server đông nhưng chưa đầy, tránh server rác bị lỗi 773
    local ApiUrl = "https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?sortOrder=Desc&limit=100"
    
    pcall(function()
        local response = game:HttpGet(ApiUrl)
        local data = HttpService:JSONDecode(response)
        
        if data and data.data then
            local validServers = {}
            for _, server in ipairs(data.data) do
                -- CHỐNG LỖI 773: Bắt buộc server phải còn trống ít nhất 3 slot (maxPlayers - 3)
                if type(server) == "table" and server.playing < (server.maxPlayers - 3) and server.id ~= game.JobId then
                    table.insert(validServers, server.id)
                end
            end
            
            if #validServers > 0 then
                local targetServer = validServers[math.random(1, #validServers)]
                TeleportService:TeleportToPlaceInstance(PlaceId, targetServer, LocalPlayer)
            else
                -- Nếu không tìm được server qua API, dùng lệnh backup của game
                Networking.AntiAfk.RequestHop:Fire()
            end
        end
    end)
end

local function findIndex(list, value)
    for index, item in ipairs(list) do if item == value then return index end end
    return 1
end

-- UI
local PetDropdown = Tabs.Pets:AddDropdown("PetDropdown", { Title = "Choose Pet", Values = DynamicPetList, Multi = false, Default = findIndex(DynamicPetList, Config.TargetPet) })
PetDropdown:OnChanged(function(Value) Config.TargetPet = Value; saveConfig() end)

local RankDropdown = Tabs.Pets:AddDropdown("RankDropdown", { Title = "Choose Rank", Values = RankList, Multi = false, Default = findIndex(RankList, Config.TargetRank) })
RankDropdown:OnChanged(function(Value) Config.TargetRank = Value; saveConfig() end)

Tabs.Pets:AddButton({
    Title = "Refresh Pets",
    Callback = function()
        local newList = {"All"}
        for pName, _ in pairs(require(RS:WaitForChild("SharedModules"):WaitForChild("PetModules"))) do table.insert(newList, pName) end
        table.sort(newList, function(a, b) return a == "All" or (b ~= "All" and a < b) end)
        PetDropdown:SetValues(newList)
        Fluent:Notify({Title = "Refreshed", Content = "Pet list updated.", Duration = 3})
    end
})

local AutoExecToggle = Tabs.Pets:AddToggle("AutoExecToggle", { Title = "Auto execute (Save State)", Default = Config.AutoExecute })
AutoExecToggle:OnChanged(function(Value) Config.AutoExecute = Value; if Value then enableAutoExecuteAfterDelay() end; saveConfig() end)

local TameToggle = Tabs.Pets:AddToggle("TameToggle", { Title = "Auto catch pet", Default = Config.AutoTameTeleport })
TameToggle:OnChanged(function(Value) Config.AutoTameTeleport = Value; saveConfig() end)

local HopToggle = Tabs.Pets:AddToggle("HopToggle", { Title = "Auto server hop", Default = Config.AutoServerHop })
HopToggle:OnChanged(function(Value) Config.AutoServerHop = Value; saveConfig() end)

-- ===================================================
-- VÒNG LẶP SĂN PET
-- ===================================================
task.spawn(function()
    while task.wait(1) do 
        if Config.AutoTameTeleport then
            pcall(function()
                local char = LocalPlayer.Character
                local hrp = char and char:FindFirstChild("HumanoidRootPart")
                local wildPetRef = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("WildPetRef")
                if not hrp or not wildPetRef then return end
                
                local hasMatchingPet = false 
                
                for _, petPart in pairs(wildPetRef:GetChildren()) do
                    if petPart:IsA("BasePart") then
                        local owner = petPart:GetAttribute("OwnerUserId")
                        local petName = petPart:GetAttribute("PetName") or ""
                        local petRarity = petPart:GetAttribute("Rarity") or "Common"
                        if petRarity == "" then petRarity = "Common" end
                        
                        if not owner or owner == 0 then
                            local matchPet = (Config.TargetPet == "All" or petName == Config.TargetPet)
                            local matchRank = (Config.TargetRank == "All" or petRarity == Config.TargetRank)
                            
                            if matchPet and matchRank then
                                hasMatchingPet = true 
                                hrp.CFrame = petPart.CFrame * CFrame.new(0, 3, 0)
                                task.wait(0.4) 
                                Networking.Pets.WildPetTame:Fire(petPart)
                                task.wait(0.6)
                            end
                        end
                    end
                end
                
                if not hasMatchingPet and Config.AutoServerHop then
                    Fluent:Notify({ Title = "Server Hop", Content = "No matching pet. Bypassing Error 773 & Hopping...", Duration = 4 })
                    CustomServerHop()
                    task.wait(12) -- Đợi 12s để tránh rate limit của Roblox gây lỗi 773
                end
            end)
        end
    end
end)

Fluent:Notify({ Title = "DanielRoblox.Store", Content = "Anti-Error 773 Hop is ready!", Duration = 5 })
