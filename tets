-- Hệ thống lưu cấu hình
local function canSaveConfig() return type(writefile) == "function" end
local function saveConfig()
    if canSaveConfig() then pcall(writefile, ConfigFileName, HttpService:JSONEncode(Config)) end
end
if canSaveConfig() and isfile(ConfigFileName) then
    pcall(function()
        local decoded = HttpService:JSONDecode(readfile(ConfigFileName))
        for k, v in pairs(decoded) do if Config[k] ~= nil then Config[k] = v end end
    end)
end

local function enableAutoExecuteAfterDelay()
    task.spawn(function()
        task.wait(3)
        if Config.AutoExecute then
            Config.AutoTameTeleport = true
            saveConfig()
        end
    end)
end
if Config.AutoExecute then enableAutoExecuteAfterDelay() end

