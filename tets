local function getUIElement(plot, upgradeKey, floor)
    if not plot then return nil end

    if upgradeKey == "ExtraSawRange" or upgradeKey == "ExtraYield" or upgradeKey == "ExtraSprinklerRange" or upgradeKey == "ExtraPower" then
        local sign = nil
        if floor == "Floor1" then
            sign = plot:FindFirstChild("PlotUpgradeSign")
        elseif floor == "Floor2" and plot:FindFirstChild("SecondFloor") then
            sign = plot.SecondFloor:FindFirstChild("PlotUpgradeSign")
        elseif floor == "Floor3" and plot:FindFirstChild("ThirdFloor") then
            sign = plot.ThirdFloor:FindFirstChild("PlotUpgradeSign")
        end

        if sign and sign:FindFirstChild("Screen") and sign.Screen:FindFirstChild("SurfaceGui") then
            local gui = sign.Screen.SurfaceGui
            if upgradeKey == "ExtraSawRange" then return gui:FindFirstChild("SawRange") end
            if upgradeKey == "ExtraYield" then return gui:FindFirstChild("SawYield") end
            if upgradeKey == "ExtraSprinklerRange" then return gui:FindFirstChild("SprinklerRange") end
            if upgradeKey == "ExtraPower" then return gui:FindFirstChild("SprinklerPower") end
        end

    elseif upgradeKey == "SeedLuck" or upgradeKey == "SeedRolls" then
        local sign = plot:FindFirstChild("UpgradeSign")
        if sign and sign:FindFirstChild("Screen") and sign.Screen:FindFirstChild("SurfaceGui") then
            return sign.Screen.SurfaceGui:FindFirstChild(upgradeKey)
        end

    elseif upgradeKey == "ExpandFarm" then
        local sign = plot:FindFirstChild("ExpandSign")
        if sign and sign:FindFirstChild("Screen") and sign.Screen:FindFirstChild("SurfaceGui") then
            return sign.Screen.SurfaceGui:FindFirstChild("Expand")
        end
    end

    return nil
end

local function createAutoScrapeToggle(name, upgradeKey, invokeFunc)
    autoStates[name] = false
    UpgradeTab:AddToggle("Auto" .. name:gsub("%s",""), { Title = "Auto " .. name, Default = false }):OnChanged(function(v)
        autoStates[name] = v
        if v then
            local getPlotRemote = findGetPlotRemote()
            if not getPlotRemote then
                task.spawn(function()
                    Fluent:Notify({Title="Error", Content="GetPlot remote not found", Duration=4})
                end)
                autoStates[name] = false
                return
            end

            task.spawn(function()
                while autoStates[name] do
                    local ok, myPlot = pcall(function() return getPlotRemote:InvokeServer() end)
                    if not ok or not myPlot then
                        task.wait(1)
                        continue
                    end

                    for floor, enabled in pairs(selectedFloors) do
                        if not enabled then continue end

                        local uiNode = getUIElement(myPlot, upgradeKey, floor)
                        if uiNode and uiNode:FindFirstChild("Btn") then
                            local btn = uiNode.Btn
                            local isGreyedOut = btn:FindFirstChild("UIGradient_Grey") and btn.UIGradient_Grey.Enabled
                            local isMax = btn:FindFirstChild("Txt") and btn.Txt.Text == "MAX"

                            if not isGreyedOut and not isMax then
                                pcall(invokeFunc, floor)
                                task.wait(0.2)
                            else
                                task.wait(0.5)
                            end
                        else
                            task.wait(0.2)
                        end
                    end
                end
            end)
        end
    end)
end

TeleportToMyFarm = function()
    local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local rootPart = character and character:WaitForChild("HumanoidRootPart", 3)
    if not rootPart then return end

    local myPlot = getMyPlot()
    if not myPlot then
        Fluent:Notify({Title="Teleport Failed", Content="Không tìm thấy plot của bạn", Duration=4})
        return
    end

    local plotModel = resolvePlotInstance(myPlot)
    if not plotModel then
        Fluent:Notify({Title="Teleport Failed", Content="Plot không hợp lệ", Duration=4})
        return
    end

    local targetCFrame
    local sign = plotModel:FindFirstChild("OwnerSign", true)
    if sign then
        local attach = sign:FindFirstChildWhichIsA("Attachment", true)
        if attach then targetCFrame = attach.WorldCFrame
        elseif sign:IsA("BasePart") then targetCFrame = sign.CFrame
        elseif sign.PrimaryPart then targetCFrame = sign.PrimaryPart.CFrame
        else
            local basePart = sign:FindFirstChildWhichIsA("BasePart", true)
            if basePart then targetCFrame = basePart.CFrame end
        end
    end

    if not targetCFrame then
        local success, pivot = pcall(function() return plotModel:GetPivot() end)
        if success and pivot then targetCFrame = pivot end
    end

    if not targetCFrame then
        local basePart = plotModel.PrimaryPart or plotModel:FindFirstChildWhichIsA("BasePart", true)
        if basePart then targetCFrame = basePart.CFrame end
    end

    if targetCFrame then
        rootPart.CFrame = targetCFrame * CFrame.new(0, 5, 0)
        return
    end
    Fluent:Notify({Title="Teleport Failed", Content="Không thể xác định vị trí farm", Duration=4})
end

