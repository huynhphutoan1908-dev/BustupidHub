                    local targetSpray = findGearTool("Spray", ConfigSpray.TargetMutation)
                    if targetSpray then
                        local clean, dirty = {}, {}
                        for _, dirt in ipairs(gearCands) do
                            local mut = dirt:GetAttribute("PlantMutation") or "Normal"
