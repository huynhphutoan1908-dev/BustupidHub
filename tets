local function isShooterTool(tool, pConfig)
    if not tool or not tool:IsA("Tool") then return false end
    return tool:GetAttribute(pConfig.Shooter.Attribute) == true or tool.Name == pConfig.Shooter.ToolName
end

local function getPlantTargets(origin, pConfig)
    local runtime = workspace:FindFirstChild("InteractiveEvents") and workspace.InteractiveEvents:FindFirstChild("PlantRush")
    if not runtime then return {} end

    local targets = {}
    for _, model in ipairs(runtime:GetDescendants()) do
        if model:IsA("Model") and model:GetAttribute("PlantRushId") then
            local part = model.PrimaryPart or model:FindFirstChild("HumanoidRootPart", true) or model:FindFirstChildWhichIsA("BasePart", true)
            if part then
                local dist = (part.Position - origin).Magnitude
                if dist > 0 and dist <= (pConfig.Shooter.Range or 100) then table.insert(targets, {part = part, dist = dist}) end
            end
        end
    end
    table.sort(targets, function(a, b) return a.dist < b.dist end)
    return targets
end

local plantRushToggleGuard = false

local function setUnifiedPlantRushState(v)
    Config.AutoPlantRush = v
    Config.AutoPlantRushCollect = v
end

AutoPlantRushToggle = EventTab:AddToggle("AutoPlantRush", { Title = "Auto Plant Rush Event", Default = false }):OnChanged(function(v)
    if plantRushToggleGuard then
        Config.AutoPlantRush = v
        Config.AutoPlantRushCollect = v
        return
    end

    if v and not DropClaimRemote then
        Fluent:Notify({Title="Error", Content="PlantRush DropClaim remote not found", Duration=4})
        plantRushToggleGuard = true
        AutoPlantRushToggle:SetValue(false)
        plantRushToggleGuard = false
        setUnifiedPlantRushState(false)
        return
    end

    setUnifiedPlantRushState(v)

    if v then
        task.spawn(function()
            local PlantRushConfig
            pcall(function() PlantRushConfig = require(ReplicatedStorage.Shared.PlantRushConfig) end)
            local prRemotes = ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("PlantRush")
            local shootRemote = prRemotes and prRemotes:FindFirstChild("Shoot")

            if not PlantRushConfig or not shootRemote then
                Fluent:Notify({Title="Error", Content="Plant Rush module not found!", Duration=3})
                plantRushToggleGuard = true
                AutoPlantRushToggle:SetValue(false)
                plantRushToggleGuard = false
                setUnifiedPlantRushState(false)
                return
            end

            while Config.AutoPlantRush do
                local nextDelay = 0.5
                local char = LocalPlayer.Character
                if char then
                    local tool = char:FindFirstChildOfClass("Tool")
                    local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")

                    if not isShooterTool(tool, PlantRushConfig) and backpack then
                        for _, item in ipairs(backpack:GetChildren()) do
                            if isShooterTool(item, PlantRushConfig) then
                                local hum = char:FindFirstChildOfClass("Humanoid")
                                if hum then hum:EquipTool(item) tool = item break end
                            end
                        end
                    end

                    if tool and isShooterTool(tool, PlantRushConfig) then
                        local cam = workspace.CurrentCamera
                        local origin = cam and cam.CFrame.Position or (char.PrimaryPart and char.PrimaryPart.Position) or Vector3.zero
                        local direction = cam and cam.CFrame.LookVector or Vector3.new(0, 0, -1)

                        local targets = getPlantTargets(origin, PlantRushConfig)
                        local positions = {}
                        local maxTargets = 10 

                        for i = 1, math.min(maxTargets, #targets) do
                            table.insert(positions, targets[i].part.Position)
                        end

                        if #positions == 0 then
                            table.insert(positions, origin + direction.Unit * (PlantRushConfig.Shooter.Range or 100))
                            nextDelay = 0.5
                        else
                            nextDelay = 1 / (PlantRushConfig.Shooter.ShotsPerSecond or 10)
                        end

                        for _, targetPos in ipairs(positions) do
                            local shotDirection = (targetPos - origin).Magnitude > 0 and (targetPos - origin).Unit or direction.Unit
                            pcall(function() shootRemote:FireServer(origin, shotDirection, targetPos) end)
                        end
                    else
                        nextDelay = 0.5
                    end
                else
                    nextDelay = 0.5
                end
                task.wait(nextDelay)
            end
        end)
    end
end)


