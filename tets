                                table.insert(clean, dirt)
                            elseif mut ~= ConfigSpray.TargetMutation then
                                table.insert(dirty, dirt)
                            end
                        end

                        if #clean > 0 then
                            equipTool(targetSpray)
                            SprayRemote:FireServer(clean[1])
                            task.wait(0.3)
                        elseif #dirty > 0 then
                            local acid = findGearTool("Spray", "None")
                            if acid then
