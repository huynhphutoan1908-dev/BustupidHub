local function equipTokenBee()
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")
    local humanoid = char and char:FindFirstChildOfClass("Humanoid")
    if not char or not backpack or not humanoid then return false end

    for _, item in pairs(char:GetChildren()) do
        if item:IsA("Tool") and (item.Name == "Honey Token" or item:GetAttribute("HoneyTokenTool") == true) then
            return true 
        end
    end

    for _, item in pairs(backpack:GetChildren()) do
        if item:IsA("Tool") and (item.Name == "Honey Token" or item:GetAttribute("HoneyTokenTool") == true) then
            humanoid:EquipTool(item)
            return true
        end
    end
    return false
end

local BeePrompts = {InsertToken = {}, CollectHoney = {}}
local function addBeePrompt(prompt)
    if not prompt:IsA("ProximityPrompt") then return end
    if prompt.ActionText == "Insert Token" or prompt.ObjectText == "Honey Pot" then
        table.insert(BeePrompts.InsertToken, prompt)
    elseif prompt.ActionText == "Collect" and prompt.ObjectText == "Honeycomb" then
        table.insert(BeePrompts.CollectHoney, prompt)
    end
end
local function removeBeePrompt(prompt)
    local function removeFrom(list)
        for i, item in ipairs(list) do
            if item == prompt then
                table.remove(list, i)
                return
            end
        end
    end
    removeFrom(BeePrompts.InsertToken)
    removeFrom(BeePrompts.CollectHoney)
end

local trackedPlantRushDrops = {}
local trackedPlantRushPrompts = {}
local lastPlantRushCollectTime = 0
local plantRushCollectDelay = 0.14
local plantRushCollectMaxDistance = 120
local plantRushTeleportThreshold = 8

local function isPlantRushDropPart(part)
    if not part or not part:IsA("BasePart") then return false end
    local name = part.Name
    return type(name) == "string" and name:match("^PlantRushLocalDrop_.+") ~= nil
end

local function getPlantRushDropId(part)
    if not isPlantRushDropPart(part) then return nil end
    return part.Name:match("^PlantRushLocalDrop_(.+)")
end

local function findPlantRushDropPart(obj)
    local current = obj
    while current do
        if isPlantRushDropPart(current) then return current end
        current = current.Parent
    end
    return nil
end

local function trackPlantRushDrop(part)
    if not isPlantRushDropPart(part) then return end
    local id = getPlantRushDropId(part)
    if id then trackedPlantRushDrops[part] = id end
end

local function untrackPlantRushDrop(part)
    trackedPlantRushDrops[part] = nil
end

local function trackPlantRushPrompt(prompt)
    local dropPart = findPlantRushDropPart(prompt.Parent or prompt)
    if not dropPart then return end
    trackedPlantRushPrompts[prompt] = dropPart
end

local function untrackPlantRushPrompt(prompt)
    trackedPlantRushPrompts[prompt] = nil
end

local function trackPlantRushDescendant(obj)
    if obj:IsA("BasePart") and isPlantRushDropPart(obj) then trackPlantRushDrop(obj)
    elseif obj:IsA("ProximityPrompt") then trackPlantRushPrompt(obj) end
end

local function cleanupPlantRushDrops()
    for part in pairs(trackedPlantRushDrops) do
        if not part or not part.Parent or not part:IsA("BasePart") then
            trackedPlantRushDrops[part] = nil
        end
    end
end

local function cleanupPlantRushPrompts()
    for prompt, dropPart in pairs(trackedPlantRushPrompts) do
        if not prompt or not prompt.Parent or not prompt:IsA("ProximityPrompt") or not dropPart or not dropPart.Parent or not dropPart:IsA("BasePart") then
            trackedPlantRushPrompts[prompt] = nil
        end
    end
end

local function getNearestTrackedPlantRushPrompt(origin)
    local closestPrompt, closestDropPart, bestDist = nil, nil, math.huge
    for prompt, dropPart in pairs(trackedPlantRushPrompts) do
        if prompt and prompt.Parent and prompt:IsA("ProximityPrompt") and dropPart and dropPart:IsA("BasePart") then
            local dist = (dropPart.Position - origin).Magnitude
            if dist < bestDist and dist <= plantRushCollectMaxDistance then
                bestDist = dist
                closestPrompt = prompt
                closestDropPart = dropPart
            end
        end
    end
    return closestPrompt, closestDropPart
end

if DropSpawnedRemote and DropSpawnedRemote:IsA("RemoteEvent") then
    DropSpawnedRemote.OnClientEvent:Connect(function(arg1, arg2)
        local dropPart, dropId = arg1, arg2
        if type(arg1) == "table" and arg1.DropId then
            dropId = arg1.DropId
            dropPart = nil
        end
        if dropPart and dropId then
            if typeof(dropPart) == "Instance" and dropPart:IsA("BasePart") and isPlantRushDropPart(dropPart) then
                trackedPlantRushDrops[dropPart] = dropId
            elseif typeof(dropPart) == "Instance" and dropPart:IsA("Model") then
                local base = dropPart:FindFirstChildWhichIsA("BasePart", true)
                if base and isPlantRushDropPart(base) then trackedPlantRushDrops[base] = dropId end
            end
        end
    end)
end

