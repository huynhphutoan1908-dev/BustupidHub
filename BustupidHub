-- 4. MODULE: AUTO GOM FRUIT (ĐÃ VIẾT LẠI HOÀN TOÀN)
-- ==========================================
-- Hàm tìm trái gần nhất
local function GetClosestFruit()
    local char = Player.Character
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root then return nil, nil end

    local logic = Workspace:FindFirstChild("Logic")
    if not logic then return nil, nil end

    local closestFruit = nil
    local closestPrompt = nil
    local shortestDist = math.huge

    local function CheckFolder(folderName)
        local folder = logic:FindFirstChild(folderName)
        if not folder then return end
        for _, item in pairs(folder:GetDescendants()) do
            if item:IsA("Model") or item:IsA("BasePart") then
                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt then
                    local targetCFrame = item:IsA("Model") and item:GetPivot() or item.CFrame
                    local dist = (root.Position - targetCFrame.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closestFruit = item
                        closestPrompt = prompt
                    end
                end
            end
        end
    end

    CheckFolder("FruitSpawns")
    CheckFolder("FruitDrops")

    return closestFruit, closestPrompt
end

-- ==========================================
-- HỆ THỐNG BAY 3 PHA: LÊN CAO → BAY NGANG → HẠ XUỐNG
-- ==========================================
local FLY_HEIGHT = 180 -- Độ cao bay (đủ cao để tránh địa hình + nước)

-- Hàm setup anti-gravity + noclip (dùng chung cho cả 3 pha)
local function SetupFlight(rootPart)
    local char = rootPart.Parent
    if not char then return nil, nil, nil end
    
    -- Xóa BodyVelocity cũ nếu còn sót
    local oldBV = rootPart:FindFirstChild("Toann_FlyBV")
    if oldBV then oldBV:Destroy() end
    
    -- 1. BodyVelocity triệt tiêu trọng lực
    local bv = Instance.new("BodyVelocity")
    bv.Name = "Toann_FlyBV"
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Parent = rootPart
    
    -- 2. Noclip liên tục mỗi frame
    local noclipConn = RunService.Stepped:Connect(function()
        if not char or not char.Parent then return end
        for _, part in pairs(char:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
    
    return bv, noclipConn, char
end

-- Hàm cleanup sau khi bay xong
local function CleanupFlight(bv, noclipConn)
    if noclipConn then pcall(function() noclipConn:Disconnect() end) end
    if bv and bv.Parent then bv:Destroy() end
end

-- Hàm bay 1 đoạn (dùng cho mỗi pha)
local function FlySegment(rootPart, fromPos, toPos, speed, bv)
    local distance = (fromPos - toPos).Magnitude
    if distance < 1 then return true end -- Đã ở vị trí rồi
    
    local duration = distance / speed
    local startTime = tick()
    local arrived = false
    
    local flyConn
    flyConn = RunService.Heartbeat:Connect(function()
        if not rootPart or not rootPart.Parent then
            flyConn:Disconnect()
            arrived = true
            return
        end
        
        local elapsed = tick() - startTime
        local alpha = math.clamp(elapsed / math.max(duration, 0.01), 0, 1)
        local newPos = fromPos:Lerp(toPos, alpha)
        
        rootPart.CFrame = CFrame.new(newPos) * rootPart.CFrame.Rotation
        bv.Velocity = Vector3.new(0, 0, 0)
        
        if alpha >= 1 then
            flyConn:Disconnect()
            arrived = true
        end
    end)
    
    -- Chờ bay xong (timeout chống treo)
    local waitTimeout = 0
    while not arrived and waitTimeout < (duration + 5) do
        task.wait(0.1)
        waitTimeout = waitTimeout + 0.1
    end
    
    if flyConn then pcall(function() flyConn:Disconnect() end) end
    return arrived
end

-- Hàm bay chính: 3 pha (LÊN → NGANG → XUỐNG)
-- Trả về bv, noclipConn để giữ anti-gravity khi lụm trái
local function FlyToFruit(rootPart, targetPos, speed)
    local bv, noclipConn, char = SetupFlight(rootPart)
    if not bv then return false, nil, nil end
    
    local startPos = rootPart.Position
    
    -- Tính độ cao bay: lấy max giữa vị trí hiện tại, vị trí trái, và FLY_HEIGHT
    local safeY = math.max(startPos.Y, targetPos.Y, FLY_HEIGHT)
    
    -- ═══ PHA 1: BAY LÊN CAO ═══
    local upPos = Vector3.new(startPos.X, safeY, startPos.Z)
    local upSpeed = speed * 1.2 -- Bay lên nhanh hơn 1 chút
    
    if not FlySegment(rootPart, startPos, upPos, upSpeed, bv) then
        CleanupFlight(bv, noclipConn)
        return false, nil, nil
    end
    
    -- Kiểm tra character còn sống
    if not rootPart or not rootPart.Parent then
        CleanupFlight(bv, noclipConn)
        return false, nil, nil
    end
    
    -- ═══ PHA 2: BAY NGANG TỚI TRÊN ĐẦU TRÁI ═══
    local abovePos = Vector3.new(targetPos.X, safeY, targetPos.Z)
    
    if not FlySegment(rootPart, upPos, abovePos, speed, bv) then
        CleanupFlight(bv, noclipConn)
        return false, nil, nil
    end
    
    if not rootPart or not rootPart.Parent then
        CleanupFlight(bv, noclipConn)
        return false, nil, nil
    end
    
    -- ═══ PHA 3: HẠ XUỐNG TRÁI ═══
    local downSpeed = speed * 0.8 -- Hạ xuống chậm hơn để không miss
    
    if not FlySegment(rootPart, abovePos, targetPos, downSpeed, bv) then
        CleanupFlight(bv, noclipConn)
        return false, nil, nil
    end
    
    -- KHÔNG cleanup ở đây! Trả về bv + noclipConn để giữ float khi lụm
    return true, bv, noclipConn
end

local function ToggleAutoFarm(state)
    if not state then
        -- Cleanup khi tắt
        local char = Player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local bv = root:FindFirstChild("Toann_FlyBV")
                if bv then bv:Destroy() end
            end
        end
        return
    end

    task.spawn(function()
        while HubState.Toggles.AutoFarm do
            local targetFruit, targetPrompt = GetClosestFruit()
            
            if targetFruit and targetPrompt then
                local char = Player.Character
                local rootPart = char and char:FindFirstChild("HumanoidRootPart")
                
                if rootPart then
                    local targetCFrame = targetFruit:IsA("Model") and targetFruit:GetPivot() or targetFruit.CFrame
                    local targetPos = targetCFrame.Position
                    
                    -- Bay 3 pha: LÊN CAO → NGANG → XUỐNG (giữ float)
                    local flyOk, flyBV, flyNoclip = FlyToFruit(rootPart, targetPos, HubState.Settings.FlySpeed)

                    if HubState.Toggles.AutoFarm and rootPart and rootPart.Parent then
                        -- Ép dịch chuyển thẳng nếu vẫn còn lệch
                        if (rootPart.Position - targetPos).Magnitude > 5 then
                            rootPart.CFrame = CFrame.new(targetPos) * rootPart.CFrame.Rotation
                            task.wait(0.1)
                        end

                        -- Spam fireproximityprompt cho đến khi trái biến mất
                        -- Vẫn giữ BodyVelocity + noclip nên không bị rơi
                        local timeout = 0
                        while targetFruit.Parent and targetPrompt.Parent and HubState.Toggles.AutoFarm and timeout < 15 do
                            pcall(function() fireproximityprompt(targetPrompt) end)
                            task.wait(0.2)
                            timeout = timeout + 1
                        end
                    end
                    
                    -- Lụm xong hoặc timeout → cleanup flight
                    CleanupFlight(flyBV, flyNoclip)
                end
            else
                task.wait(1) -- Nếu không có trái nào, chờ 1s rồi quét lại
            end
        end
    end)
end

