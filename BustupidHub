-- 2. MODULE: SERVER RADAR (TÍCH HỢP AUTO HOP - ĐÃ FIX)
-- ==========================================
local function StartRadar(statusLabel)
    local noFruitTimer = 0 

    task.spawn(function()
        while task.wait(1) do
            local success, err = pcall(function()
                local fruitCount = 0
                local fruitNames = {}

                local logic = Workspace:FindFirstChild("Logic")
                if not logic then
                    statusLabel.Text = "Lỗi: Không tìm thấy thư mục Logic"
                    statusLabel.TextColor3 = Color3.fromRGB(255, 255, 0)
                    return
                end

                local function ProcessForRadar(obj)
                    if not obj or obj:IsA("Folder") then return end
                    local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then
                        fruitCount = fruitCount + 1
                        local cleanName = obj.Name:gsub("Fruit", ""):gsub("_Model", ""):gsub("Drop", "")
                        table.insert(fruitNames, cleanName)
                    end
                end

                local function Scan(folderName)
                    local folder = logic:FindFirstChild(folderName)
                    if not folder then return end
                    for _, item in pairs(folder:GetChildren()) do
                        if item:IsA("Folder") then
                            for _, subItem in pairs(item:GetChildren()) do ProcessForRadar(subItem) end
                        else ProcessForRadar(item) end
                    end
                end

                Scan("FruitDrops")
                Scan("FruitSpawns")

                if fruitCount > 0 then
                    noFruitTimer = 0 
                    local displayNames = {}
                    for i = 1, math.min(fruitCount, 2) do table.insert(displayNames, fruitNames[i]) end
                    local suffix = fruitCount > 2 and "..." or ""
                    
                    statusLabel.Text = "Map có: " .. fruitCount .. " trái (" .. table.concat(displayNames, ", ") .. suffix .. ")"
                    statusLabel.TextColor3 = Color3.fromRGB(85, 255, 127)
                else
                    if HubState.Toggles.AutoHop then
                        noFruitTimer = noFruitTimer + 1
                        local remaining = HubState.Settings.HopDelay - noFruitTimer
                        statusLabel.Text = "Hết hàng! Hop Server trong: " .. remaining .. "s"
                        statusLabel.TextColor3 = Color3.fromRGB(255, 170, 0)

                        if noFruitTimer >= HubState.Settings.HopDelay then
                            statusLabel.Text = "Đang chuyển Server..."
                            statusLabel.TextColor3 = Color3.fromRGB(255, 60, 60)
                            
                            local hopResult = ServerHop()
                            
                            -- FIX 8: Nếu hop thất bại, reset timer và hiển thị lỗi
                            if not hopResult then
                                noFruitTimer = 0
                                statusLabel.Text = "Hop thất bại! Thử lại sau " .. HubState.Settings.HopDelay .. "s"
                                statusLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
                            end
                            
                            task.wait(10) 
                        end
                    else
                        statusLabel.Text = "Trạng thái: Sạch bóng (Đang chờ)"
                        statusLabel.TextColor3 = Color3.fromRGB(255, 100, 100)
                    end
                end
            end)

            if not success then
                statusLabel.Text = "Đang kết nối lại Radar..."
                statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
            end
        end
    end)
end

