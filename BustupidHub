-- FIX 1: Lưu danh sách server đã visit để không hop lại
local VisitedServers = { [game.JobId] = true }

local function ServerHop()
    local placeId = game.PlaceId
    -- sortOrder=Desc: ưu tiên server đông người (thường có fruit hơn)
    local url = "https://games.roblox.com/v1/games/" .. placeId .. "/servers/Public?sortOrder=Desc&excludeFullGames=true&limit=100"
    
    local success, result = pcall(function() return game:HttpGet(url) end)

    if not success then
        warn("[HazeHub] Lỗi HTTP khi lấy danh sách server: " .. tostring(result))
        return false
    end

    local decodeOk, data = pcall(function() return HttpService:JSONDecode(result) end)
    if not decodeOk or not data or not data.data then
        warn("[HazeHub] Lỗi decode JSON server list")
        return false
    end

    for _, server in ipairs(data.data) do
        -- Kiểm tra: đủ người + chưa đầy + chưa visit + không phải server hiện tại
        if server.playing and server.maxPlayers 
            and server.playing >= HubState.Settings.MinPlayersHop  -- Bỏ qua server ít người
            and server.playing < server.maxPlayers - 1 
            and server.id ~= game.JobId 
            and not VisitedServers[server.id] then
            
            -- Đánh dấu server này là đã visit
            VisitedServers[server.id] = true
            
            -- FIX 5: Wrap teleport trong pcall để bắt lỗi
            local teleportOk, teleportErr = pcall(function()
                TeleportService:TeleportToPlaceInstance(placeId, server.id, Player)
            end)
            
            if teleportOk then
                -- FIX 6: RETURN ngay sau khi teleport thành công, không chạy tiếp loop
                return true
            else
                warn("[HazeHub] Teleport thất bại tới server " .. server.id .. ": " .. tostring(teleportErr))
                -- Tiếp tục thử server khác
            end
        end
    end

    -- FIX 7: Nếu đã hết server mới → reset danh sách visited để thử lại
    warn("[HazeHub] Đã hết server mới, reset danh sách visited...")
    VisitedServers = { [game.JobId] = true }
    return false
end

