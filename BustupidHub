local function ToggleESP(state)
    if not state then
        if HubState.Connections.EspDrops then HubState.Connections.EspDrops:Disconnect() end
        if HubState.Connections.EspSpawns then HubState.Connections.EspSpawns:Disconnect() end
        for _, obj in pairs(Workspace:GetDescendants()) do
            if obj.Name == "Toann_ESP_HL" or obj.Name == "Toann_ESP_BG" then obj:Destroy() end
        end
        return
    end

    local logic = Workspace:FindFirstChild("Logic")
    if not logic then return end

    local function ScanForESP(folderName)
        local folder = logic:FindFirstChild(folderName)
        if not folder then return end
        for _, item in pairs(folder:GetChildren()) do
            if item:IsA("Folder") then
                for _, subItem in pairs(item:GetChildren()) do ApplyESP(subItem) end
            else ApplyESP(item) end
        end
    end

    ScanForESP("FruitSpawns")
    ScanForESP("FruitDrops")

    local spawns = logic:FindFirstChild("FruitSpawns")
    local drops = logic:FindFirstChild("FruitDrops")

    if spawns then HubState.Connections.EspSpawns = spawns.DescendantAdded:Connect(function(c) task.wait(0.5) ApplyESP(c) end) end
    if drops then HubState.Connections.EspDrops = drops.DescendantAdded:Connect(function(c) task.wait(0.5) ApplyESP(c) end) end
end

