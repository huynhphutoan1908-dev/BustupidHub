-- 2. KILL AURA (Safe Mode)
MainTab:CreateSection("Combat / Kill Aura (Safe Mode)")

local killAuraEnabled = false
local k_MAX_TARGETS = 8
local k_FIRE_DELAY = 0.03
local k_lastFire = 0
local k_CurrentWeapon = nil

local function k_UpdateWeapon()
    local character = Players.LocalPlayer.Character
    if not character then
        k_CurrentWeapon = nil
        return
    end
    k_CurrentWeapon = nil
    for _, v in ipairs(character:GetChildren()) do
        if v:IsA("Tool") then
            k_CurrentWeapon = v.Name
            break
        end
    end
end

local function k_SetupCharacter(character)
    k_UpdateWeapon()
    character.ChildAdded:Connect(function(child)
        if child:IsA("Tool") then k_CurrentWeapon = child.Name end
    end)
    character.ChildRemoved:Connect(function(child)
        if child:IsA("Tool") and k_CurrentWeapon == child.Name then
            task.wait()
            k_UpdateWeapon()
        end
    end)
end

if Players.LocalPlayer.Character then k_SetupCharacter(Players.LocalPlayer.Character) end
Players.LocalPlayer.CharacterAdded:Connect(k_SetupCharacter)

local function k_GetClosestZombies()
    local character = Players.LocalPlayer.Character
    local hrp = character and character:FindFirstChild("HumanoidRootPart")
    local ZombiesFolder = workspace:FindFirstChild("Zombies_Local")
    
    if not hrp or not ZombiesFolder then return {} end

    local zombieList = {}
    for _, zombie in ipairs(ZombiesFolder:GetChildren()) do
        if zombie:IsA("Model") then
            local pos = zombie:GetPivot().Position
            local distance = (hrp.Position - pos).Magnitude
            table.insert(zombieList, {Model = zombie, Distance = distance, Position = pos})
        end
    end

    table.sort(zombieList, function(a, b) return a.Distance < b.Distance end)
    return zombieList
end

RunService.Heartbeat:Connect(function()
    if not killAuraEnabled then return end
    if tick() - k_lastFire < k_FIRE_DELAY then return end
    
    local GunRemotes = ReplicatedStorage:FindFirstChild("GunRemotes")
    local GunRemote = GunRemotes and GunRemotes:FindFirstChild("GunHit")
    if not GunRemote then return end

    k_lastFire = tick()

    if not k_CurrentWeapon then k_UpdateWeapon() end
    if not k_CurrentWeapon then return end

    local targets = k_GetClosestZombies()
    local sent = 0

    for _, data in ipairs(targets) do
        if sent >= k_MAX_TARGETS then break end
        local zombie = data.Model
        local zombieId = tonumber(zombie.Name:match("%d+"))

        if zombieId then
            GunRemote:FireServer(k_CurrentWeapon, zombieId, data.Position)
            sent += 1
        end
    end
end)

